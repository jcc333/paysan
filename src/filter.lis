import "go:net/http"
import "types"

interface Filter {
  fn matches(req: RequestWrapper) -> bool
}

struct PathFilter {
  path: string,
}

impl PathFilter {
  fn matches(self, req: RequestWrapper) -> bool {
    req.path() == Some(self.path)
  }
}

fn path(p: string) {
  PathFilter { path: p }
}

struct MethodFilter {
  method: Method,
}

impl MethodFilter {
  fn matches(self, req: RequestWrapper) -> bool {
    Method.read(req.method()) == Some(self.method)
  }
}

struct AndFilter {
  f1: Filter,
  f2: Filter,
}

impl AndFilter {
  fn matches(self, req: RequestWrapper) -> bool {
    self.f1.matches(req) && self.f2.matches(req)
  }
}

fn and(f1: Filter, f2: Filter) -> Filter {
  AndFilter { f1, f2 }
}

struct OrFilter {
  f1: Filter,
  f2: Filter,
}

impl OrFilter {
  fn matches(self, req: RequestWrapper) -> bool {
    self.f1.matches(req) || self.f2.matches(req)
  }
}

fn or(f1: Filter, f2: Filter) -> Filter {
  OrFilter { f1, f2 }
}

struct NotFilter {
  f: Filter,
}

impl NotFilter {
  fn matches(self, req: RequestWrapper) -> bool {
    !self.f.matches(req)
  }
}

fn not(f: Filter) -> Filter {
  NotFilter { f }
}
