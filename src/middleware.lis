import "go:net/http"

interface Middleware<A: http.Request, B: http.Request> {
  fn apply(req: A) -> Result<B, error>
}

struct ChainedMiddleware<A: http.Request, B: http.Request, C: http.Request> {
  m1: Middleware<A, B>,
  m2: Middleware<B, C>,
}

impl ChainedMiddleware<A, B, C> {
  fn apply(self, req: A) -> Result<C, error> {
    let intermediate = self.m1.apply(req)?
    self.m2.apply(intermediate)
  }
}

fn chain<A: http.Request, B: http.Request, C: http.Request>(m1: Middleware<A, B>, m2: Middleware<B, C>) -> Middleware<A, C> {
  ChainedMiddleware { m1, m2 }
}

fn then<A: http.Request, B: http.Request, C: http.Request>(m1: Middleware<A, B>, m2: Middleware<B, C>) -> Middleware<A, C> {
  chain(m1, m2)
}

struct AroundMiddleware<A: http.Request, B: http.Request, C: http.Request> {
  before: Middleware<A, B>,
  after: Middleware<B, C>,
}

impl AroundMiddleware<A, B, C> {
  fn apply(self, req: A) -> Result<C, error> {
    let intermediate = self.before.apply(req)?
    self.after.apply(intermediate)
  }
}

fn around<A: http.Request, B: http.Request, C: http.Request>(before: Middleware<A, B>, after: Middleware<B, C>) -> Middleware<A, C> {
  AroundMiddleware { before, after }
}